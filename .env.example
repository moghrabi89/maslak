# 🧭 مسلك - درب الشافعي | نموذج المتغيرات البيئية (.env.example)
# قم بنسخ هذا الملف وتسميته إلى .env في جذر المشروع لتشغيل بيئة التطوير.

# =========================================================================
# 🗄️ 1. قاعدة البيانات (PostgreSQL / Neon)
# =========================================================================
# رابط الاتصال بقاعدة البيانات Neon PostgreSQL.
# تأكد من تفعيل الاتصال عبر Neon Pooling (بإضافة -pooler) لضمان استقرار جلسات الاتصال HTTP.
DATABASE_URL="postgresql://username:password@ep-blue-wave-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# =========================================================================
# 🔑 2. نظام الهوية والمصادقة (Clerk Authentication)
# =========================================================================
# مفاتيح Clerk للتحكم بتسجيل دخول الطلاب والإدارة.
# مفتاح الواجهة الأمامية العام (Public API Publishable Key)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# المفتاح السري للخلفية (Clerk Secret API Key)
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# مسارات التوجيه الافتراضية لكليرك داخل التطبيق (مهمة لمنع التوجيه لصفحات كليرك الخارجية)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# =========================================================================
# ☁️ 3. نظام رفع الملفات والصور (UploadThing)
# =========================================================================
# إعدادات رفع صور الشارات وصور الحسابات الشخصية للطلاب.
UPLOADTHING_SECRET="sk_live_your_uploadthing_secret_key_here"
UPLOADTHING_APP_ID="xxxxxxxxxx"
